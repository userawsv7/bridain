# AI API Keys (choose one or use free alternatives)

# Groq API (Fast & Free tier available)
# Get your free API key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Alternative Free APIs:

# Hugging Face (Free tier)
# Get token at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_hf_token_here

# Together AI (Free credits)
# Sign up at: https://api.together.xyz
TOGETHER_API_KEY=your_together_key_here

# OpenRouter (Free tier with many models)
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# Note: The app works without any API keys using built-in responses!